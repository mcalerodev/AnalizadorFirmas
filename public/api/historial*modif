<?php

session_start();

require_once __DIR__ . '/../../src/Database/Conexion.php';
require_once __DIR__ . '/../../src/Repository/ArchivoRepository.php';

$conexion = Conexion::getInstance();
$repo = new ArchivoRepository($conexion);

// =====================
// ELIMINAR UNO
// =====================
if (isset($_GET['eliminar'])) {
    $repo->eliminar($_GET['eliminar']);
    header("Location: historial.php");
    exit;
}

// =====================
// ELIMINAR MÚLTIPLES
// =====================
if (isset($_POST['eliminar_varios'])) {
    if (!empty($_POST['ids'])) {
        foreach ($_POST['ids'] as $id) {
            $repo->eliminar($id);
        }
    }
    header("Location: historial.php");
    exit;
}

// =====================
// FILTROS
// =====================
$tipo   = $_GET['tipo'] ?? null;
$fecha  = $_GET['fecha'] ?? null;
$buscar = $_GET['buscar'] ?? null;

// =====================
// PAGINACIÓN
// =====================
$pagina = isset($_GET['pagina']) ? (int)$_GET['pagina'] : 1;
$limite = 5;
$offset = ($pagina - 1) * $limite;

// Datos base
$archivos = $repo->obtenerHistorial($tipo, $fecha);

// BUSCAR
if ($buscar) {
    $archivos = array_filter($archivos, function ($a) use ($buscar) {
        return stripos($a['nombre_original'], $buscar) !== false;
    });
}

// total
$total = count($archivos);
$paginas = ceil($total / $limite);

// slice paginación
$archivos = array_slice($archivos, $offset, $limite);

?>

